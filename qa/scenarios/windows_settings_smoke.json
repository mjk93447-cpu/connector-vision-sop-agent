{
  "version": "1.0",
  "title": "Windows Settings Smoke",
  "metadata": {
    "purpose": "Verify OCR-first navigation across common Windows Settings pages without destructive changes.",
    "risk_level": "low",
    "expected_os": "Windows 10/11"
  },
  "steps": [
    {
      "id": "open_settings",
      "name": "Open Settings",
      "type": "press_key",
      "key": "winleft+i",
      "enabled": true
    },
    {
      "id": "wait_settings",
      "name": "Wait Settings",
      "type": "wait_ms",
      "ms": 2500,
      "enabled": true
    },
    {
      "id": "open_personalization",
      "name": "Open Personalization",
      "type": "click",
      "target": "personalization_nav",
      "button_text": "Personalization",
      "roi": [1180, 180, 600, 780],
      "enabled": true
    },
    {
      "id": "wait_personalization",
      "name": "Wait Personalization",
      "type": "wait_ms",
      "ms": 1500,
      "enabled": true
    },
    {
      "id": "open_colors",
      "name": "Open Colors",
      "type": "click",
      "target": "colors_nav",
      "button_text": "Colors",
      "roi": [1180, 180, 600, 780],
      "enabled": true
    },
    {
      "id": "wait_colors",
      "name": "Wait Colors",
      "type": "wait_ms",
      "ms": 1200,
      "enabled": true
    },
    {
      "id": "open_background",
      "name": "Open Background",
      "type": "click",
      "target": "background_nav",
      "button_text": "Background",
      "roi": [1180, 180, 600, 780],
      "enabled": true
    },
    {
      "id": "wait_background",
      "name": "Wait Background",
      "type": "wait_ms",
      "ms": 1200,
      "enabled": true
    }
  ]
}
