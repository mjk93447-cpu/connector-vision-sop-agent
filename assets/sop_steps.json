{
  "version": "1.3",
  "steps": [
    {
      "id": "login",
      "name": "Login",
      "type": "auth_sequence",
      "login_button": "login_button",
      "password_field": "password_field",
      "ok_button": "ok_button",
      "button_texts": {
        "login_button": "LOGIN",
        "password_field": "PASSWORD",
        "ok_button": "OK"
      },
      "description": "Click LOGIN → enter password (1111) → click OK to authenticate",
      "enabled": true
    },
    {
      "id": "open_recipe",
      "name": "Recipe Menu",
      "type": "click",
      "target": "recipe_button",
      "button_text": "RECIPE",
      "description": "Click RECIPE MENU button to load connector recipe file",
      "enabled": true
    },
    {
      "id": "mold_left",
      "name": "Mold Left",
      "type": "mold_setup",
      "label_target": "mold_left_label",
      "label_text": "MOLD LEFT",
      "drag_start": [100, 200],
      "drag_end": [800, 350],
      "roi": [0, 0, 960, 1080],
      "description": "Click MOLD LEFT label then drag to define left mold ROI",
      "enabled": true
    },
    {
      "id": "mold_right",
      "name": "Mold Right",
      "type": "mold_setup",
      "label_target": "mold_right_label",
      "label_text": "MOLD RIGHT",
      "drag_start": [100, 200],
      "drag_end": [800, 350],
      "roi": [960, 0, 1920, 1080],
      "description": "Click MOLD RIGHT label then drag to define right mold ROI",
      "enabled": true
    },
    {
      "id": "axis_x",
      "name": "Axis-X",
      "type": "input_text",
      "target": "axis_x_field",
      "button_text": "AXIS-X",
      "text": "0",
      "clear_first": true,
      "description": "Click AXIS-X field and enter X-axis reference coordinate",
      "enabled": true
    },
    {
      "id": "axis_y",
      "name": "Axis-Y",
      "type": "input_text",
      "target": "axis_y_field",
      "button_text": "AXIS-Y",
      "text": "0",
      "clear_first": true,
      "description": "Click AXIS-Y field and enter Y-axis reference coordinate",
      "enabled": true
    },
    {
      "id": "pin_scan",
      "name": "Pin Array",
      "type": "validate_pins",
      "description": "Scan connector pin array. YOLO26x detects pin positions in top half.",
      "target_type": "NON_TEXT",
      "pin_position": "top",
      "pin_count_expected": 20,
      "yolo_detect": "connector_pin",
      "roi": [400, 300, 1120, 480],
      "enabled": true
    },
    {
      "id": "pin_count",
      "name": "Pin Count",
      "type": "validate_pins",
      "description": "Validate total pin count. YOLO26x detects connector pins in bottom half.",
      "target_type": "NON_TEXT",
      "pin_position": "bottom",
      "pin_count_expected": 20,
      "yolo_detect": "connector_pin",
      "roi": [400, 600, 1120, 780],
      "enabled": true
    },
    {
      "id": "verify_left",
      "name": "Verify Left",
      "type": "click",
      "target": "verify_left_button",
      "button_text": "VERIFY L",
      "description": "Click VERIFY L to confirm left connector positioning",
      "enabled": true
    },
    {
      "id": "verify_right",
      "name": "Verify Right",
      "type": "click",
      "target": "verify_right_button",
      "button_text": "VERIFY R",
      "description": "Click VERIFY R to confirm right connector positioning",
      "enabled": true
    },
    {
      "id": "save",
      "name": "Save",
      "type": "click",
      "target": "save_button",
      "button_text": "SAVE",
      "description": "Save current recipe configuration",
      "enabled": true
    },
    {
      "id": "apply",
      "name": "Apply",
      "type": "click_sequence",
      "targets": ["apply_button", "open_icon"],
      "button_texts": ["APPLY", "OPEN"],
      "description": "Click APPLY to commit settings then OPEN to launch recipe",
      "enabled": true
    }
  ]
}
